{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 900,
  "height": 250,

  "background": "#0B1020",

  "title": {
    "text": "After 2018, Australia's Space Industry Accelerates Rapidly",
    "subtitle": "Timeline of policy, launches, and commercial investment surged after the Australian Space Agency was formed",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 26,
    "subtitleFont": "Inter",
    "subtitleFontSize": 14,
    "anchor": "start",
    "offset": 20
  },

  "data": {
    "url": "https://raw.githubusercontent.com/rsal0030/2179-dv2/main/data/milestones.json"
  },

  "transform": [
    {
      "window": [
        {
          "op": "row_number",
          "as": "index"
        }
      ]
    },

    {
      "window": [
        {
          "op": "row_number",
          "as": "year_index"
        }
      ],
      "groupby": ["year"]
    },

    {
      "joinaggregate": [
        {
          "op": "count",
          "as": "year_count"
        }
      ],
      "groupby": ["year"]
    },

    {
      "calculate": "(datum.year_index - (datum.year_count + 1)/2) * 45",
      "as": "x_offset"
    },

    {
      "calculate": "datum.index % 2 == 0 ? 'bottom' : 'top'",
      "as": "side"
    },

    {
      "calculate":
        "length(datum.label) > 20 ? substring(datum.label,0,22) + '…' : datum.label",
      "as": "wrapped_label"
    }
  ],

  "layer": [

    {
      "mark": {
        "type": "rule",
        "stroke": "#3B82F6",
        "strokeWidth": 2.3
      },

      "encoding": {
        "y": {
          "value": 105
        }
      }
    },

    {
      "transform": [
        {
          "filter": "datum.highlight == true"
        }
      ],

      "mark": {
        "type": "circle",
        "size": 900,
        "opacity": 0.15,
        "color": "#FFB703"
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "xOffset": {
          "field": "x_offset",
          "type": "quantitative"
        },

        "y": {
          "value": 105
        }
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 320,
        "stroke": "#FFFFFF",
        "strokeWidth": 1.5
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",

          "axis": {
            "title": null,
            "labelColor": "#EAEAEA",
            "labelFont": "Inter",
            "labelFontSize": 15,
            "tickColor": "#2A324A",
            "domainColor": "#2A324A",
            "grid": false
          }
        },

        "xOffset": {
          "field": "x_offset",
          "type": "quantitative"
        },

        "y": {
          "value": 105
        },

        "color": {
          "field": "category",
          "type": "nominal",

          "scale": {
            "domain": [
              "policy",
              "infrastructure",
              "science",
              "launch",
              "satellite",
              "people"
            ],

            "range": [
              "#5DA9FF",
              "#FFB703",
              "#90BE6D",
              "#F94144",
              "#8ECAE6",
              "#C77DFF"
            ]
          },

          "legend": {
            "title": "Milestone Type",
            "orient": "bottom",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },

          {
            "field": "label",
            "type": "nominal",
            "title": "Milestone"
          },

          {
            "field": "description",
            "type": "nominal",
            "title": "Description"
          }
        ]
      }
    },

    {
      "transform": [
        {
          "filter": "datum.side == 'top'"
        }
      ],

      "mark": {
        "type": "rule",
        "stroke": "#94A3B8",
        "opacity": 0.6,
        "strokeWidth": 1.5
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "xOffset": {
          "field": "x_offset",
          "type": "quantitative"
        },

        "y": {
          "value": 105
        },

        "y2": {
          "value": 48
        }
      }
    },

    {
      "transform": [
        {
          "filter": "datum.side == 'bottom'"
        }
      ],

      "mark": {
        "type": "rule",
        "stroke": "#94A3B8",
        "opacity": 0.6,
        "strokeWidth": 1.5
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "xOffset": {
          "field": "x_offset",
          "type": "quantitative"
        },

        "y": {
          "value": 105
        },

        "y2": {
          "value": 172
        }
      }
    },

    {
      "transform": [
        {
          "filter": "datum.side == 'top'"
        }
      ],

      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 9,
        "fontWeight": "bold",
        "fill": "#EAEAEA",
        "align": "center",
        "baseline": "bottom",
        "lineHeight": 14
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "xOffset": {
          "field": "x_offset",
          "type": "quantitative"
        },

        "y": {
          "value": 28
        },

        "text": {
          "field": "wrapped_label"
        }
      }
    },

    {
      "transform": [
        {
          "filter": "datum.side == 'bottom'"
        }
      ],

      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 9,
        "fontWeight": "bold",
        "fill": "#EAEAEA",
        "align": "center",
        "baseline": "top",
        "lineHeight": 14
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "xOffset": {
          "field": "x_offset",
          "type": "quantitative"
        },

        "y": {
          "value": 182
        },

        "text": {
          "field": "wrapped_label"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "grid": false
    },

    "axisX": {
      "labelPadding": 10,
      "labelFontWeight": "bold"
    },

    "axisY": {
      "grid": false,
      "domain": false,
      "ticks": false,
      "labels": false,
      "title": null
    },

    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter"
      
    }
  }
}