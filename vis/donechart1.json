{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 900,
  "height": 350,

  "background": "#0B1020",

  "title": {
    "text": "After 2018, Australia's Space Industry Accelerates Rapidly",
    "subtitle": "Timeline of policy, launches, and commercial investment surged after the Australian Space Agency was formed",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 26,
    "subtitleFont": "Inter",
    "subtitleFontSize": 14,
    "anchor": "start",
    "offset": 20
  },

  "data": {
    "url": "https://raw.githubusercontent.com/rsal0030/2179-dv2/main/data/milestones.json"
  },

  "transform": [
    {
      "window": [
        {
          "op": "row_number",
          "as": "index"
        }
      ]
    },

    {
      "calculate": "datum.index % 2 == 0 ? 40 : 210",
      "as": "label_y"
    },

    {
      "calculate": "replace(replace(replace(datum.label, ' Agency ', ' Agency\\n'), ' Satellite ', ' Satellite\\n'), ' Mission ', ' Mission\\n')",
      "as": "wrapped_label"
    }
  ],

  "layer": [

    {
      "mark": {
        "type": "rule",
        "stroke": "#5DA9FF",
        "strokeWidth": 3
      },

      "encoding": {
        "y": {
          "value": 125
        }
      }
    },

    {
      "transform": [
        {
          "filter": "datum.highlight == true"
        }
      ],

      "mark": {
        "type": "circle",
        "size": 900,
        "opacity": 0.15,
        "color": "#FFB703"
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "y": {
          "value": 125
        }
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 320,
        "stroke": "#FFFFFF",
        "strokeWidth": 1.5
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",

          "axis": {
            "title": null,
            "labelColor": "#EAEAEA",
            "labelFont": "Inter",
            "labelFontSize": 15,
            "tickColor": "#2A324A",
            "domainColor": "#2A324A",
            "grid": false
          }
        },

        "y": {
          "value": 125
        },

        "color": {
          "field": "category",
          "type": "nominal",

          "scale": {
            "domain": [
              "policy",
              "infrastructure",
              "science",
              "launch",
              "satellite",
              "people"
            ],

            "range": [
              "#5DA9FF",
              "#FFB703",
              "#90BE6D",
              "#F94144",
              "#8ECAE6",
              "#C77DFF"
            ]
          },

          "legend": {
            "title": "Milestone Type",
            "orient": "bottom",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },

          {
            "field": "label",
            "type": "nominal",
            "title": "Milestone"
          },

          {
            "field": "description",
            "type": "nominal",
            "title": "Description"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "rule",
        "stroke": "#9AA5B1",
        "strokeWidth": 1.5
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "y": {
          "value": 125
        },

        "y2": {
          "field": "label_y",
          "type": "quantitative"
        }
      }
    },

    {
      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 11,
        "fontWeight": "bold",
        "fill": "#EAEAEA",
        "align": "center",
        "baseline": "middle",
        "lineHeight": 14,
        "limit": 120
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "y": {
          "field": "label_y",
          "type": "quantitative"
        },

        "text": {
          "field": "wrapped_label"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    },

    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}