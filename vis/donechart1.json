{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 900,
  "height": 220,

  "background": "#0B1020",

  "title": {
    "text": "Australia's Return to Space",
    "subtitle": "Major milestones in the rise of Australia's modern space industry",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 26,
    "subtitleFont": "Inter",
    "subtitleFontSize": 14,
    "anchor": "start",
    "offset": 20
  },

  "data": {
    "url": "../data/milestones.json"
  },

  "layer": [
    {
      "mark": {
        "type": "rule",
        "stroke": "#5DA9FF",
        "strokeWidth": 3
      },

      "encoding": {
        "y": {
          "value": 110
        }
      }
    },

    {
      "transform": [
        {
          "filter": "datum.highlight == true"
        }
      ],

      "mark": {
        "type": "circle",
        "size": 800,
        "opacity": 0.15,
        "color": "#FFB703"
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "y": {
          "value": 110
        }
      }
    },

    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 300,
        "stroke": "#FFFFFF",
        "strokeWidth": 1.5
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": null,
            "labelColor": "#EAEAEA",
            "labelFont": "Inter",
            "labelFontSize": 13,
            "tickColor": "#2A324A",
            "domainColor": "#2A324A",
            "grid": false
          }
        },

        "y": {
          "value": 110
        },

        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": [
              "policy",
              "infrastructure",
              "science",
              "launch",
              "satellite",
              "people"
            ],

            "range": [
              "#5DA9FF",
              "#FFB703",
              "#90BE6D",
              "#F94144",
              "#8ECAE6",
              "#C77DFF"
            ]
          },

          "legend": {
            "title": "Milestone Type",
            "orient": "bottom",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },

          {
            "field": "label",
            "type": "nominal",
            "title": "Milestone"
          },

          {
            "field": "description",
            "type": "nominal",
            "title": "Description"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "rule",
        "stroke": "#9AA5B1",
        "strokeWidth": 1.5
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "y": {
          "value": 110
        },

        "y2": {
          "field": "label_y",
          "type": "quantitative"
        }
      }
    },

    {
      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": "bold",
        "fill": "#EAEAEA",
        "align": "center",
        "baseline": "middle",
        "lineBreak": "\n"
      },

      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },

        "y": {
          "field": "label_y",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    },

    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}