{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 500,
  "height": 500,

  "background": "#0B1020",

  "params": [
    {
      "name": "purposeFilter",
      "value": "All",
      "bind": {
        "input": "select",
        "options": [
          "All",
          "Research",
          "Commercial",
          "Other"
        ],
        "name": "Filter by Purpose: "
      }
    }
  ],

  "title": {
    "text": "Australia’s Satellite Activity Took Off After 2018",
    "subtitle": "Australia’s orbital activity surged after 2018, driven by commercial and research missions",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 28,
    "subtitleFont": "Inter",
    "subtitleFontSize": 14,
    "anchor": "start",
    "offset": 20
  },

  "data": {
    "url": "../data/aosd.csv"
  },

  "transform": [
    {
      "calculate": "toNumber(datum['Launch year'])",
      "as": "launch_year"
    },

    {
      "filter": "isValid(datum.launch_year)"
    },

    {
      "calculate": "toString(datum.Satellite || datum['Satellite '] || datum[' Satellite'] || datum['\\uFEFFSatellite'] || '')",
      "as": "Satellite_clean"
    },

    {
      "calculate": "indexof(lower(datum['Mission purpose']), 'research') >= 0 || indexof(lower(datum['Mission purpose']), 'science') >= 0 ? 'Research' : indexof(lower(datum['Mission purpose']), 'commercial') >= 0 || indexof(lower(datum['Mission purpose']), 'communication') >= 0 ? 'Commercial' : indexof(lower(datum['Mission purpose']), 'defence') >= 0 || indexof(lower(datum['Mission purpose']), 'military') >= 0 ? 'Defence' : 'Other'",
      "as": "Purpose"
    },

    {
      "filter": "purposeFilter == 'All' || datum.Purpose == purposeFilter"
    },

    {
      "filter": "datum.Satellite_clean != ''"
    },

    {
      "window": [
        {
          "op": "row_number",
          "as": "rank"
        }
      ],
      "groupby": ["launch_year"]
    }
  ],

  "layer": [
    {
      "selection": {
        "hover": {
          "type": "single",
          "fields": ["Satellite_clean"],
          "nearest": true,
          "on": "mouseover",
          "empty": "none",
          "clear": "mouseout"
        }
      },

      "mark": {
        "type": "circle",
        "stroke": "#FFFFFF",
        "strokeWidth": 1,
        "strokeOpacity": 0.5
      },

      "encoding": {
        "x": {
          "field": "launch_year",
          "type": "ordinal",
          "sort": "ascending",
          "axis": {
            "title": "Launch Year",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "grid": false,
            "labelAngle": 0,
            "domainColor": "#2A324A",
            "tickColor": "#2A324A",
            "labelFont": "Inter",
            "titleFont": "Inter",
            "labelOverlap": "greedy",
            "labelPadding": 8
          }
        },

        "y": {
          "field": "rank",
          "type": "quantitative",
          "axis": {
            "title": "Number of Satellite Launches",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "gridColor": "#1C2236",
            "domainColor": "#2A324A",
            "tickColor": "#2A324A",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "size": {
          "condition": {
            "selection": "hover",
            "value": 260
          },
          "value": 110
        },

        "opacity": {
          "condition": {
            "selection": "hover",
            "value": 1
          },
          "value": 0.55
        },

        "color": {
          "field": "Purpose",
          "type": "nominal",
          "scale": {
            "range": [
              "#5DA9FF",
              "#FFB703",
              "#FB8500",
              "#90BE6D",
              "#B5179E",
              "#43AA8B"
            ]
          },
          "legend": {
            "title": "Mission Purpose",
            "labelColor": "#EAEAEA",
            "titleColor": "#EAEAEA"
          }
        },

        "tooltip": [
          {
            "field": "Satellite_clean",
            "title": "Satellite"
          },
          {
            "field": "launch_year",
            "title": "Launch Year"
          },
          {
            "field": "Purpose",
            "title": "Purpose"
          },
          {
            "field": "Operator",
            "title": "Operator"
          }
        ]
      }
    },

    {
      "data": {
        "values": [
          {
            "launch_year": "2018"
          }
        ]
      },

      "mark": {
        "type": "rule",
        "color": "#FFFFFF",
        "strokeDash": [4, 4],
        "opacity": 0.4
      },

      "encoding": {
        "x": {
          "field": "launch_year",
          "type": "ordinal"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "launch_year": "2018",
            "rank": 15,
            "label": "Launch acceleration begins after 2018"
          }
        ]
      },

      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "dy": -10,
        "font": "Inter",
        "fontSize": 14,
        "fontWeight": "bold",
        "color": "#FFFFFF"
      },

      "encoding": {
        "x": {
          "field": "launch_year",
          "type": "ordinal"
        },

        "y": {
          "field": "rank",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    },

    {
      "mark": {
        "type": "text",
        "dy": -10,
        "font": "Inter",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#9AA5B1"
      },

      "encoding": {
        "x": {
          "field": "launch_year",
          "type": "ordinal"
        },

        "y": {
          "aggregate": "count",
          "field": "Satellite_clean"
        },

        "text": {
          "aggregate": "count",
          "field": "Satellite_clean"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 14
    },

    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}