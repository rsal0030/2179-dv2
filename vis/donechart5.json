{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 540,

  "background": "#0B1020",

  "params": [
    {
      "name": "purposeFilter",
      "value": "All",
      "bind": {
        "input": "select",
        "options": [
          "All",
          "Research",
          "Commercial",
          "Other"
        ],
        "name": "Filter by Purpose: "
      }
    }
  ],

  "title": {
    "text": ["After Decades of Silence, Australia Suddenly Reached Orbit",
      "at Scale"],
    "subtitle": ["Driven by the rise of commercial space activity and small satellite deployments, the number of satellites launched from Australia has", "surged since 2018."],
    "anchor": "start",
    "font": "Orbitron",
    "fontSize": 28,
    "fontWeight": "bold",
    "color": "#FFFFFF",
    "subtitleFont": "Inter",
    "subtitleFontSize": 14,
    "subtitleColor": "#9AA5B1",
    "offset": 20
  },

  "data": {
    "url": "https://raw.githubusercontent.com/rsal0030/2179-dv2/main/data/aosd.csv"
  },

  "transform": [

    {
      "calculate": "toNumber(datum['Launch year'])",
      "as": "launch_year"
    },

    {
      "filter": "isValid(datum.launch_year)"
    },

    {
      "calculate": "toString(datum.Satellite || datum['Satellite '] || datum[' Satellite'] || datum['\\uFEFFSatellite'] || '')",
      "as": "Satellite_clean"
    },

    {
      "calculate": "indexof(lower(datum['Mission purpose']), 'research') >= 0 || indexof(lower(datum['Mission purpose']), 'science') >= 0 ? 'Research' : indexof(lower(datum['Mission purpose']), 'commercial') >= 0 || indexof(lower(datum['Mission purpose']), 'communication') >= 0 ? 'Commercial' : 'Other'",
      "as": "Purpose"
    },

    {
      "filter": "purposeFilter == 'All' || datum.Purpose == purposeFilter"
    },

    {
      "filter": "datum.Satellite_clean != ''"
    },

    {
      "window": [
        {
          "op": "row_number",
          "as": "rank"
        }
      ],
      "groupby": ["launch_year"]
    }
  ],

  "layer": [

    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "count",
              "field": "Satellite_clean",
              "as": "launches"
            }
          ],
          "groupby": ["launch_year"]
        }
      ],

      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 5,
        "cornerRadiusTopRight": 5
      },

      "encoding": {

        "x": {
          "field": "launch_year",
          "type": "ordinal",

          "sort": {
            "field": "launch_year",
            "order": "ascending"
          },

          "scale": {
            "paddingInner": 0.35,
            "paddingOuter": 0.2
          },

          "axis": {
            "title": "Launch Year",
            "labelAngle": 0,
            "grid": false,
            "labelColor": "#EAEAEA",
            "titleColor": "#EAEAEA",
            "domainColor": "#2A324A",
            "tickColor": "#2A324A",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "y": {
          "field": "launches",
          "type": "quantitative",

          "axis": {
            "title": "Satellites Launched",
            "gridColor": "#1C2236",
            "labelColor": "#EAEAEA",
            "titleColor": "#EAEAEA",
            "domainColor": "#2A324A",
            "tickColor": "#2A324A",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "color": {
          "condition": {
            "test": "datum.launch_year >= 2018",
            "value": "#5B7FA3"
          },
          "value": "#2A3448"
        },

        "opacity": {
          "condition": {
            "test": "datum.launch_year >= 2018",
            "value": 0.7
          },
          "value": 0.26
        },

        "tooltip": [
          {
            "field": "launch_year",
            "title": "Year"
          },
          {
            "field": "launches",
            "title": "Launches"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "circle",
        "size": 650,
        "opacity": 0.06,
        "color": "#60A5FA"
      },

      "encoding": {

        "x": {
          "field": "launch_year",
          "type": "ordinal",

          "sort": {
            "field": "launch_year",
            "order": "ascending"
          }
        },

        "y": {
          "field": "rank",
          "type": "quantitative"
        }
      }
    },

    {
      "selection": {
        "hover": {
          "type": "single",
          "fields": ["Satellite_clean"],
          "nearest": true,
          "on": "mouseover",
          "empty": "none",
          "clear": "mouseout"
        }
      },

      "mark": {
        "type": "circle",
        "stroke": "#FFFFFF",
        "strokeWidth": 1,
        "strokeOpacity": 0.5
      },

      "encoding": {

        "x": {
          "field": "launch_year",
          "type": "ordinal",

          "sort": {
            "field": "launch_year",
            "order": "ascending"
          }
        },

        "y": {
          "field": "rank",
          "type": "quantitative"
        },

        "size": {
          "condition": {
            "selection": "hover",
            "value": 280
          },
          "value": 110
        },

        "opacity": {
          "condition": {
            "selection": "hover",
            "value": 1
          },

          "condition": {
            "test": "datum.launch_year >= 2018",
            "value": 0.95
          },

          "value": 0.3
        },

        "color": {
          "field": "Purpose",
          "type": "nominal",

          "scale": {
            "domain": [
              "Research",
              "Commercial",
              "Other"
            ],

            "range": [
              "#10B981",
              "#F59E0B",
              "#60A5FA"
            ]
          },

          "legend": {
            "title": "Mission Purpose",
            "labelColor": "#EAEAEA",
            "titleColor": "#EAEAEA",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "tooltip": [
          {
            "field": "Satellite_clean",
            "title": "Satellite"
          },
          {
            "field": "launch_year",
            "title": "Launch Year"
          },
          {
            "field": "Purpose",
            "title": "Purpose"
          },
          {
            "field": "Operator",
            "title": "Operator"
          }
        ]
      }
    },

    {
      "data": {
        "values": [
          {
            "launch_year": 2018
          }
        ]
      },

      "mark": {
        "type": "rule",
        "color": "#FFFFFF",
        "strokeDash": [6, 6],
        "strokeWidth": 2,
        "opacity": 0.5
      },

      "encoding": {

        "x": {
          "field": "launch_year",
          "type": "ordinal"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "launch_year": 2018,
            "rank": 11.2,
            "label": "More satellites launched after 2018\nthan in all previous decades combined"
          }
        ]
      },

      "mark": {
        "type": "text",
        "align": "left",
        "dx": -140,
        "dy": -10,
        "font": "Inter",
        "fontSize": 15,
        "fontWeight": "bold",
        "lineBreak": "\n",
        "color": "#FFFFFF"
      },

      "encoding": {

        "x": {
          "field": "launch_year",
          "type": "ordinal"
        },

        "y": {
          "field": "rank",
          "type": "quantitative"
        },

        "text": {
          "field": "label"
        }
      }
    },

    {
      "transform": [
        {
          "aggregate": [
            {
              "op": "count",
              "field": "Satellite_clean",
              "as": "launches"
            }
          ],
          "groupby": ["launch_year"]
        }
      ],

      "mark": {
        "type": "text",
        "dy": -10,
        "font": "Inter",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#CBD5E1"
      },

      "encoding": {

        "x": {
          "field": "launch_year",
          "type": "ordinal",

          "sort": {
            "field": "launch_year",
            "order": "ascending"
          }
        },

        "y": {
          "field": "launches",
          "type": "quantitative"
        },

        "text": {
          "field": "launches"
        }
      }
    }

  ],

  "config": {

    "view": {
      "stroke": null
    },

    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 14
    },

    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}