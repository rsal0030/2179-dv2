{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 420,

  "background": "#0B1020",

  "title": {
    "text": "Australia’s Satellite Activity Took Off After 2018",
    "subtitle": "Each dot = one satellite launch, grouped by year and coloured by mission purpose",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 24,
    "subtitleFont": "Inter",
    "subtitleFontSize": 14,
    "anchor": "start",
    "offset": 20
  },

  "data": {
    "url": "../data/aosd.csv"
  },

  "transform": [
    {
      "calculate": "toNumber(datum['Launch year'])",
      "as": "launch_year"
    },

    {
      "filter": "isValid(datum.launch_year)"
    },

    {
      "calculate": "toString(datum.Satellite || datum['Satellite '] || datum[' Satellite'] || datum['\uFEFFSatellite'] || '')",
      "as": "Satellite_clean"
    },

    {
      "calculate": "datum['Mission purpose'] && datum['Mission purpose'] !== '' ? datum['Mission purpose'] : 'Unknown Purpose'",
      "as": "Purpose"
    },

    {
      "filter": "datum.Satellite_clean != ''"
    },

    {
      "window": [
        {
          "op": "row_number",
          "as": "rank"
        }
      ],
      "groupby": ["launch_year"]
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "circle",
        "size": 140,
        "stroke": "#FFFFFF",
        "strokeWidth": 1
      },

      "encoding": {
        "x": {
          "field": "launch_year",
          "type": "ordinal",
          "axis": {
            "title": "Launch Year",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "grid": false,
            "labelAngle": 0,
            "domainColor": "#2A324A",
            "tickColor": "#2A324A",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "y": {
          "field": "rank",
          "type": "quantitative",
          "axis": {
            "title": "Satellites (stacked)",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "gridColor": "#1C2236",
            "domainColor": "#2A324A",
            "tickColor": "#2A324A",
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },

        "color": {
          "field": "Purpose",
          "type": "nominal",
          "scale": {
            "range": [
              "#5DA9FF",
              "#FFB703",
              "#FB8500",
              "#90BE6D",
              "#B5179E",
              "#43AA8B"
            ]
          },
          "legend": {
            "title": "Mission Purpose",
            "labelColor": "#EAEAEA",
            "titleColor": "#EAEAEA"
          }
        },

        "tooltip": [
          {
            "field": "Satellite_clean",
            "title": "Satellite"
          },
          {
            "field": "launch_year",
            "title": "Launch Year"
          },
          {
            "field": "Purpose",
            "title": "Purpose"
          },
          {
            "field": "Operator",
            "title": "Operator"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "dy": -10,
        "font": "Inter",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#9AA5B1"
      },

      "encoding": {
        "x": {
          "field": "launch_year",
          "type": "ordinal"
        },

        "y": {
          "aggregate": "count",
          "field": "Satellite_clean"
        },

        "text": {
          "aggregate": "count",
          "field": "Satellite_clean"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 14
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}