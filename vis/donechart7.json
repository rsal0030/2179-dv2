{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "background": "#071028",

  "width": "container",
  "height": 520,

  "title": {
    "text": "Orbit Type Strongly Determines Satellite Mass",
    "subtitle": "LEO vs GEO mass distribution with statistical structure",
    "anchor": "start",
    "font": "Orbitron",
    "fontSize": 24,
    "color": "#FFFFFF",
    "subtitleColor": "#94A3B8"
  },

  "data": {
    "url": "https://raw.githubusercontent.com/rsal0030/2179-dv2/main/data/aosd.csv"
  },

  "transform": [
    {
      "filter": "datum['Launch Mass(kg)'] != null && datum.OrbitType != null"
    },
    {
      "filter": "trim(datum.OrbitType) == 'LEO' || trim(datum.OrbitType) == 'GEO'"
    },
    {
      "calculate": "trim(datum.OrbitType)",
      "as": "Orbit"
    },
    {
      "calculate": "isValid(datum['Satellite']) ? datum['Satellite'] : 'Unnamed Satellite'",
      "as": "Satellite_clean"
    },
    {
      "calculate": "random() * 0.35 - 0.175",
      "as": "jitter"
    }
  ],

  "layer": [

    {
      "mark": {
        "type": "errorband",
        "extent": "iqr",
        "color": "#1E3A8A",
        "opacity": 0.25
      },
      "encoding": {
        "x": {
          "field": "Orbit",
          "type": "nominal",
          "sort": ["LEO", "GEO"]
        },
        "y": {
          "field": "Launch Mass(kg)",
          "type": "quantitative"
        }
      }
    },

    {
      "mark": {
        "type": "rule",
        "color": "#60A5FA",
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "Orbit",
          "type": "nominal",
          "sort": ["LEO", "GEO"]
        },
        "y": {
          "aggregate": "median",
          "field": "Launch Mass(kg)"
        }
      }
    },

    {
      "mark": {
        "type": "text",
        "dy": -10,
        "color": "#E5E7EB",
        "fontSize": 12
      },
      "encoding": {
        "x": {
          "field": "Orbit",
          "type": "nominal",
          "sort": ["LEO", "GEO"]
        },
        "y": {
          "aggregate": "median",
          "field": "Launch Mass(kg)"
        },
        "text": {
          "aggregate": "median",
          "field": "Launch Mass(kg)",
          "format": ".0f"
        }
      }
    },

    {
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "stroke": "#FFFFFF",
        "strokeWidth": 1
      },

      "encoding": {
        "x": {
          "field": "Orbit",
          "type": "nominal",
          "sort": ["LEO", "GEO"]
        },

        "xOffset": {
          "field": "jitter"
        },

        "y": {
          "field": "Launch Mass(kg)",
          "type": "quantitative",
          "scale": { "type": "log" },

          "axis": {
            "title": "Launch Mass (kg, log scale)",
            "titleColor": "#E5E7EB",
            "labelColor": "#E5E7EB",
            "gridColor": "#1E293B"
          }
        },

        "color": {
          "field": "Orbit",
          "type": "nominal",
          "scale": {
            "domain": ["LEO", "GEO"],
            "range": ["#60A5FA", "#34D399"]
          },
          "legend": null
        },

        "tooltip": [
          { "field": "Satellite_clean", "title": "Satellite" },
          { "field": "Orbit", "title": "Orbit" },
          { "field": "Launch Mass(kg)", "title": "Mass (kg)" }
        ]
      }
    }
  ],

  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}