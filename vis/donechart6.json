{
  "$schema": "https://vega.github.io/schema/vega/v5.json",

  "width": 940,
  "height": 520,
  "padding": 12,
  "background": "#0B1020",

  "title": {
    "text": "Distribution of Australian Satellite Missions",
    "subtitle": "Treemap showing relative share of satellite mission purposes",
    "anchor": "start",
    "font": "Orbitron",
    "fontSize": 24,
    "fontWeight": "bold",
    "color": "white",
    "subtitleColor": "#AAB4C3",
    "offset": 18
  },

  "data": [
    {
      "name": "tree",

      "values": [
        { "id": "root" },

        { "id": "Communications", "parent": "root", "value": 20 },
        { "id": "Earth Observation", "parent": "root", "value": 15 },
        { "id": "Technology Demo", "parent": "root", "value": 12 },
        { "id": "Research", "parent": "root", "value": 10 },
        { "id": "Navigation", "parent": "root", "value": 8 }
      ],

      "transform": [
        {
          "type": "stratify",
          "key": "id",
          "parentKey": "parent"
        },

        {
          "type": "treemap",
          "field": "value",
          "sort": {
            "field": "value",
            "order": "descending"
          },
          "round": true,
          "paddingInner": 6,
          "paddingOuter": 2,
          "size": [
            { "signal": "width" },
            { "signal": "height" }
          ]
        },

        {
          "type": "filter",
          "expr": "datum.depth > 0"
        },

        {
          "type": "formula",
          "as": "label",
          "expr": "datum.id + '\\n' + datum.value + ' satellites'"
        }
      ]
    }
  ],

  "scales": [
    {
      "name": "color",

      "type": "ordinal",

      "domain": [
        "Communications",
        "Earth Observation",
        "Technology Demo",
        "Research",
        "Navigation"
      ],

      "range": [
        "#4CC9F0",
        "#4895EF",
        "#4361EE",
        "#7209B7",
        "#F72585"
      ]
    }
  ],

"marks": [
  {
    "type": "rect",

    "from": {
      "data": "tree"
    },

    "encode": {
      "enter": {
        "x": { "field": "x0" },
        "y": { "field": "y0" },
        "x2": { "field": "x1" },
        "y2": { "field": "y1" },

        "fill": {
          "scale": "color",
          "field": "id"
        },

        "stroke": {
          "value": "#111827"
        },

        "strokeWidth": {
          "value": 1.5
        },

        "cornerRadius": {
          "value": 4
        }
      },

      "update": {
        "stroke": {
          "value": "#111827"
        },

        "strokeWidth": {
          "value": 1.5
        },

        "fillOpacity": {
          "value": 1
        }
      },

      "hover": {
        "stroke": {
          "value": "white"
        },

        "strokeWidth": {
          "value": 2.5
        },

        "fillOpacity": {
          "value": 0.9
        }
      }
    }
  },

{
  "type": "text",

  "from": {
    "data": "tree"
  },

  "encode": {
    "enter": {
      "x": {
        "signal": "(datum.x0 + datum.x1)/2"
      },

      "y": {
        "signal": "(datum.y0 + datum.y1)/2"
      },

      "text": {
        "signal": "[datum.id, datum.value + ' satellites']"
      },

      "align": {
        "value": "center"
      },

      "baseline": {
        "value": "middle"
      },

      "fill": {
        "value": "white"
      },

      "font": {
        "value": "Inter"
      },

      "fontWeight": {
        "value": "bold"
      },

      "fontSize": {
        "value": 16
      },

      "lineHeight": {
        "value": 24
      }
    }
  }
}

  ]
}