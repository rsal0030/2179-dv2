{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 420,
  "background": "#0B1020",

  "title": {
    "text": [
      "Australia’s Space Industry Accelerated After the Australian Space Agency Was",
      "Formed"
    ],
    "subtitle": "Revenue and employment growth strengthened after 2019",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 20,
    "subtitleFont": "Inter",
    "subtitleFontSize": 13,
    "anchor": "start",
    "offset": 18
  },

  "data": {
    "values": [
      { "financial_year": "2017", "revenue_billion": 4.3, "employment": 10430 },
      { "financial_year": "2019", "revenue_billion": 4.6, "employment": 11560 },
      { "financial_year": "2020", "revenue_billion": 5.7, "employment": 15234 },
      { "financial_year": "2023", "revenue_billion": 8.0, "employment": 19595 }
    ]
  },

  "resolve": {
    "scale": { "y": "independent" }
  },

  "layer": [

    {
      "mark": {
        "type": "line",
        "strokeWidth": 4,
        "color": "#4DA3FF",
        "point": {
          "filled": true,
          "size": 120,
          "fill": "#4DA3FF",
          "stroke": "white",
          "strokeWidth": 1.5
        }
      },
      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal",
          "axis": {
            "title": "Financial Year",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "domain": false,
            "ticks": false,

            "labelAngle": 0,
            "labelAlign": "center",
            "labelBaseline": "top",

            "labelFont": "Inter",
            "titleFont": "Inter",
            "labelFontSize": 12,
            "labelFontWeight": "bold"
          }
        },

        "y": {
          "field": "revenue_billion",
          "type": "quantitative",
          "scale": { "domain": [4, 8.2] },
          "axis": {
            "title": "Revenue (AUD $Billions)",
            "titleColor": "#4DA3FF",
            "labelColor": "#4DA3FF",
            "gridColor": "#1A2238",
            "domain": false,
            "ticks": false
          }
        },

        "tooltip": [
          { "field": "financial_year", "type": "ordinal", "title": "Year" },
          {
            "field": "revenue_billion",
            "type": "quantitative",
            "title": "Revenue (Billion)",
            "format": "$.1f",
            "formatType": "number"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "line",
        "strokeWidth": 4,
        "color": "#72E3C0",
        "point": {
          "filled": true,
          "size": 120,
          "fill": "#72E3C0",
          "stroke": "white",
          "strokeWidth": 1.5
        }
      },
      "encoding": {
        "x": { "field": "financial_year", "type": "ordinal" },
        "y": {
          "field": "employment",
          "type": "quantitative",
          "scale": { "domain": [10000, 20000] },
          "axis": {
            "orient": "right",
            "title": "Employment",
            "titleColor": "#72E3C0",
            "labelColor": "#72E3C0",
            "format": ",",
            "domain": false,
            "ticks": false
          }
        },

        "tooltip": [
          { "field": "financial_year", "type": "ordinal", "title": "Year" },
          { "field": "employment", "type": "quantitative", "title": "Employment" }
        ]
      }
    }
  ],

  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}