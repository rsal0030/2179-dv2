{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 420,

  "background": "#0B1020",

  "title": {
    "text": [
      "Australia’s Space Industry Accelerated After the Australian Space Agency Was",
      "Formed"
    ],
    "subtitle": "Revenue and employment growth strengthened after 2019",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 20,
    "subtitleFont": "Inter",
    "subtitleFontSize": 13,
    "anchor": "start",
    "offset": 18
  },

  "data": {
    "values": [
      { "financial_year": "2017", "revenue_billion": 4.3, "employment": 10430 },
      { "financial_year": "2019", "revenue_billion": 4.6, "employment": 11560 },
      { "financial_year": "2020", "revenue_billion": 5.7, "employment": 15234 },
      { "financial_year": "2023", "revenue_billion": 8.0, "employment": 19595 }
    ]
  },

  "resolve": {
    "scale": {
      "y": "independent"
    }
  },

  "layer": [

    {
      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal",
          "axis": {
            "title": "Financial Year",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "domain": false,
            "ticks": false,
            "labelFont": "Inter",
            "titleFont": "Inter"
          }
        },
        "y": {
          "field": "revenue_billion",
          "type": "quantitative",
          "scale": { "domain": [4, 8.2] },
          "axis": {
            "title": "Revenue (AUD $Billions)",
            "titleColor": "#4DA3FF",
            "labelColor": "#4DA3FF",
            "gridColor": "#1A2238",
            "domain": false,
            "ticks": false,
            "labelPadding": 8,
            "titleFont": "Inter",
            "labelFont": "Inter"
          }
        },
        "tooltip": [
          { "field": "financial_year", "type": "ordinal", "title": "Year" },
          { "field": "revenue_billion", "type": "quantitative", "title": "Revenue" }
        ]
      },
      "mark": {
        "type": "line",
        "strokeWidth": 4,
        "color": "#4DA3FF",
        "point": {
          "filled": true,
          "size": 110,
          "fill": "#4DA3FF"
        }
      }
    },

    {
      "encoding": {
        "x": { "field": "financial_year", "type": "ordinal" },
        "y": {
          "field": "employment",
          "type": "quantitative",
          "scale": { "domain": [10000, 20000] },
          "axis": {
            "orient": "right",
            "title": "Employment",
            "titleColor": "#72E3C0",
            "labelColor": "#72E3C0",
            "format": ",",
            "grid": false,
            "domain": false,
            "ticks": false,
            "labelPadding": 8,
            "titleFont": "Inter",
            "labelFont": "Inter"
          }
        },
        "tooltip": [
          { "field": "financial_year", "type": "ordinal", "title": "Year" },
          { "field": "employment", "type": "quantitative", "title": "Employment" }
        ]
      },
      "mark": {
        "type": "line",
        "strokeWidth": 4,
        "color": "#72E3C0",
        "point": {
          "filled": true,
          "size": 110,
          "fill": "#72E3C0"
        }
      }
    },

    {
      "data": {
        "values": [{ "financial_year": "2019" }]
      },
      "mark": {
        "type": "rule",
        "stroke": "#FFB703",
        "strokeDash": [6, 4],
        "strokeWidth": 2,
        "opacity": 0.6
      },
      "encoding": {
        "x": { "field": "financial_year", "type": "ordinal" }
      }
    },

    {
      "data": {
        "values": [
          {
            "financial_year": "2019",
            "label": "Australian Space Agency Formed"
          }
        ]
      },
      "mark": {
        "type": "text",
        "dx": 10,
        "dy": -15,
        "font": "Inter",
        "fontSize": 11,
        "fontWeight": "bold",
        "fill": "#FFB703"
      },
      "encoding": {
        "x": { "field": "financial_year", "type": "ordinal" },
        "y": { "value": 80 },
        "text": { "field": "label" }
      }
    }
  ],

  "config": {
    "view": { "stroke": null }
  }
}