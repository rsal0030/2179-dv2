{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 420,
  "background": "#0B1020",

  "title": {
    "text": [
      "Australia’s Space Industry Accelerated After the Australian Space Agency Was",
      "Formed"
    ],
    "subtitle": "Revenue and employment growth strengthened after 2019",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 20,
    "subtitleFont": "Inter",
    "subtitleFontSize": 13,
    "anchor": "start",
    "offset": 18
  },

  "data": {
    "values": [
      { "financial_year": "2017", "revenue_billion": 4.3, "employment": 10430 },
      { "financial_year": "2019", "revenue_billion": 4.6, "employment": 11560 },
      { "financial_year": "2020", "revenue_billion": 5.7, "employment": 15234 },
      { "financial_year": "2023", "revenue_billion": 8.0, "employment": 19595 }
    ]
  },

  "resolve": {
    "scale": { "y": "independent" }
  },

  "layer": [


    {
      "transform": [
        {
          "calculate": "'$' + format(datum.revenue_billion, '.1f') + 'B'",
          "as": "revenue_label"
        }
      ],

      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 3,
        "color": "#4DA3FF",
        "point": {
          "filled": true,
          "size": 90,
          "fill": "#4DA3FF",
          "stroke": "white",
          "strokeWidth": 1.2
        }
      },

      "encoding": {
        "x": {
          "field": "financial_year",
          "type": "ordinal",
          "axis": {
            "title": "Financial Year",
            "titleColor": "#EAEAEA",
            "labelColor": "#EAEAEA",
            "domain": false,
            "ticks": false,
            "labelFontSize": 12,
            "titleFontSize": 14,
            "labelAngle": 0,
            "labelFont": "Inter",
            "labelFontWeight": "bold"
          }
        },

        "y": {
          "field": "revenue_billion",
          "type": "quantitative",
          "scale": { "domain": [4, 8.2] },
          "axis": {
            "title": "Revenue (AUD $B)",
            "titleColor": "#4DA3FF",
            "labelColor": "#4DA3FF",
            "gridColor": "#1A2238",
            "domain": false,
            "ticks": false
          }
        },

        "tooltip": [
          { "field": "financial_year", "title": "Year" },
          { "field": "revenue_label", "title": "Revenue" }
        ]
      }
    },


    {
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "strokeWidth": 3,
        "color": "#72E3C0",
        "point": {
          "filled": true,
          "size": 90,
          "fill": "#72E3C0",
          "stroke": "white",
          "strokeWidth": 1.2
        }
      },

      "encoding": {
        "x": { "field": "financial_year", "type": "ordinal" },

        "y": {
          "field": "employment",
          "type": "quantitative",
          "scale": { "domain": [10000, 20000] },
          "axis": {
          "orient": "right",
          "title": "Employment",
          "titleColor": "#72E3C0",
          "labelColor": "#72E3C0",
          "format": ".2s",
          "domain": false,
          "ticks": false,
          "labelFont": "Inter",
          "titleFont": "Inter"
        }
        },

        "tooltip": [
          { "field": "financial_year", "title": "Year" },
          { "field": "employment", "title": "Employment" }
        ]
      }
    }
  ],

  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}