{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",

  "width": 950,
  "height": 500,

  "background": "#0B1020",

  "title": {
    "text": "Global Space Agencies",
    "subtitle": "Year of National Space Agency Foundation",
    "color": "#FFFFFF",
    "subtitleColor": "#9AA5B1",
    "font": "Orbitron",
    "fontSize": 22,
    "subtitleFont": "Inter",
    "subtitleFontSize": 14,
    "anchor": "start",
    "offset": 15
  },

  "data": {
    "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
    "format": {
      "type": "topojson",
      "feature": "countries"
    }
  },

  "transform": [
    {
      "calculate":
        "datum.id == 840 ? 1958 : datum.id == 156 ? 1993 : datum.id == 356 ? 1969 : datum.id == 643 ? 1992 : datum.id == 392 ? 2003 : datum.id == 36 ? 2018 : null",
      "as": "founded"
    },

    {
      "calculate":
        "datum.id == 840 ? 'United States' : datum.id == 156 ? 'China' : datum.id == 356 ? 'India' : datum.id == 643 ? 'Russia' : datum.id == 392 ? 'Japan' : datum.id == 36 ? 'Australia' : 'No Agency Data'",
      "as": "country"
    }
  ],

  "projection": {
    "type": "equalEarth"
  },

  "mark": {
    "type": "geoshape",
    "stroke": "#1E293B",
    "strokeWidth": 0.7
  },

  "encoding": {
    "color": {
      "field": "founded",
      "type": "quantitative",

      "scale": {
        "range": [
          "#5DA9FF",
          "#8ECAE6",
          "#90BE6D",
          "#FFB703",
          "#F94144"
        ],
        "reverse": true
      },

      "legend": {
        "title": "Founded",
        "titleColor": "#EAEAEA",
        "labelColor": "#EAEAEA",
        "gradientLength": 250,
        "orient": "bottom",
        "direction": "horizontal"
      }
    },

    "tooltip": [
      {
        "field": "country",
        "title": "Country"
      },
      {
        "field": "founded",
        "title": "Founded"
      }
    ]
  },

  "config": {
    "background": "#0B1020",

    "view": {
      "stroke": null
    },

    "style": {
      "guide-label": {
        "fill": "#EAEAEA",
        "font": "Obitron"
      },

      "guide-title": {
        "fill": "#EAEAEA",
        "font": "Inter"
      }
    }
  }
}