{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 440,

  "background": "#07111F",

  "padding": {
    "top": 20,
    "left": 20,
    "right": 20,
    "bottom": 20
  },

  "title": {
    "text": "Australia’s Space Sector Has Rapidly Expanded",
    "subtitle": [
      "Number of Australian space organisations over time"
    ],
    "anchor": "start",
    "font": "Orbitron",
    "fontSize": 24,
    "fontWeight": 700,
    "color": "#FFFFFF",
    "subtitleFont": "Inter",
    "subtitleFontSize": 13,
    "subtitleColor": "#94A3B8",
    "offset": 18
  },

  "data": {
    "url": "https://raw.githubusercontent.com/rsal0030/2179-dv2/main/data/organisations.csv"
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "axis": {
        "title": "Financial Year",
        "titleFont": "Inter",
        "titleFontSize": 14,
        "titleColor": "#E2E8F0",
        "labelFont": "Inter",
        "labelFontSize": 12,
        "labelColor": "#E2E8F0",
        "labelAngle": 0,
        "domainColor": "#334155",
        "tickColor": "#334155",
        "grid": false
      }
    },

    "y": {
      "field": "organisations",
      "type": "quantitative",
      "axis": {
        "title": "Number of Organisations",
        "titleFont": "Inter",
        "titleFontSize": 14,
        "titleColor": "#E2E8F0",
        "labelFont": "Inter",
        "labelFontSize": 12,
        "labelColor": "#E2E8F0",
        "domainColor": "#334155",
        "tickColor": "#334155",
        "grid": true,
        "gridColor": "#FFFFFF",
        "gridOpacity": 0.06
      }
    }
  },

  "layer": [

    {
      "mark": {
        "type": "rule",
        "strokeWidth": 5,
        "color": "#4CC9F0",
        "opacity": 0.85,
        "strokeCap": "round"
      },

      "encoding": {
        "y2": {
          "datum": 0
        }
      }
    },

    {
      "mark": {
        "type": "circle",
        "size": 900,
        "color": "#FFD166",
        "opacity": 0.12
      }
    },

    {
      "mark": {
        "type": "circle",
        "size": 220,
        "color": "#FFD166",
        "stroke": "#FFFFFF",
        "strokeWidth": 1.8
      },

      "encoding": {
        "tooltip": [
          {
            "field": "year",
            "title": "Financial Year"
          },
          {
            "field": "organisations",
            "title": "Organisations"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "dy": -18,
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#FFFFFF"
      },

      "encoding": {
        "text": {
          "field": "organisations"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },

    "style": {
      "guide-label": {
        "font": "Inter"
      },

      "guide-title": {
        "font": "Inter"
      }
    }
  }
}