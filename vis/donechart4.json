{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": 400,

  "background": "#07111F",

  "padding": {
    "top": 40,
    "left": 25,
    "right": 30,
    "bottom": 20
  },

  "title": {
    "text": ["Australia’s Space Sector Is Rapidly Expanding, Pushing Past",
      "Obstacles"],
    "subtitle": [
      "Annual count of Australian space organisations across financial years"
    ],
    "anchor": "start",
    "font": "Orbitron",
    "fontSize": 24,
    "fontWeight": 700,
    "color": "#FFFFFF",
    "subtitleFont": "Inter",
    "subtitleFontSize": 13,
    "subtitleColor": "#94A3B8",
    "offset": 20
  },

  "data": {
    "url": "https://raw.githubusercontent.com/rsal0030/2179-dv2/main/data/organisations.csv"
  },

  "transform": [
    {
      "calculate": "datum.year === '2022-23'",
      "as": "isLatest"
    }
  ],

  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "sort": null,

      "axis": {
        "title": "Financial Year",

        "titleFont": "Inter",
        "titleFontSize": 14,
        "titleColor": "#E2E8F0",

        "labelFont": "Inter",
        "labelFontSize": 12,
        "labelColor": "#E2E8F0",
        "labelAngle": 0,

        "domain": false,
        "ticks": false,
        "grid": false
      }
    },

    "y": {
      "field": "organisations",
      "type": "quantitative",
      "scale": {
        "domainMin": 0,
        "nice": true
      },

      "axis": {
        "title": "Number of Organisations",

        "titleFont": "Inter",
        "titleFontSize": 14,
        "titleColor": "#E2E8F0",

        "labelFont": "Inter",
        "labelFontSize": 12,
        "labelColor": "#CBD5E1",

        "domain": false,
        "ticks": false,

        "grid": true,
        "gridColor": "#FFFFFF",
        "gridOpacity": 0.05
      }
    }
  },

  "layer": [

    {
      "mark": {
        "type": "rule",
        "color": "#38BDF8",
        "opacity": 0.18,
        "strokeWidth": 8
      },

      "encoding": {
        "y": {
          "datum": 0
        }
      }
    },

    {
      "mark": {
        "type": "rule",
        "strokeCap": "round",
        "strokeWidth": 5
      },

      "encoding": {

        "y2": {
          "datum": 0
        },

        "color": {
          "condition": {
            "test": "datum.isLatest",
            "value": "#FFD166"
          },
          "value": "#38BDF8"
        },

        "opacity": {
          "condition": {
            "test": "datum.isLatest",
            "value": 1
          },
          "value": 0.55
        }
      }
    },

    {
      "mark": {
        "type": "circle",
        "size": 950,
        "color": "#FFD166",
        "opacity": 0.14
      }
    },

    {
      "mark": {
        "type": "circle",
        "size": 220,
        "color": "#FFD166",
        "stroke": "#FFFFFF",
        "strokeWidth": 1.8
      },

      "encoding": {
        "tooltip": [
          {
            "field": "year",
            "title": "Financial Year"
          },
          {
            "field": "organisations",
            "title": "Organisations"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "dy": -24,
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#FFFFFF"
      },

      "encoding": {
        "text": {
          "field": "organisations"
        }
      }
    },

    {
      "transform": [
        {
          "filter": "datum.isLatest"
        }
      ],

      "mark": {
        "type": "text",
        "align": "left",
        "dx": 35,
        "dy": -35,

        "font": "Inter",
        "fontSize": 13,
        "fontWeight": 600,

        "lineBreak": "\n",
        "color": "#FFD166"
      },

      "encoding": {
        "text": {
          "value": "Australian space organisations\nhave rapidly expanded\nin the last decade"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}